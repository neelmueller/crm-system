generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int                     @id @default(autoincrement())
  email                 String                  @unique @db.VarChar(255)
  password_hash         String
  name                  String
  role                  String?
  email_verified        Boolean?                @default(false)
  verification_token    String?                 @map("verfication_token")
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  appointments          appointments[]
  password_reset_tokens password_reset_tokens[]

  @@map("users")
}

model SchemaMigration {
  filename    String    @id
  executed_at DateTime? @default(now()) @db.Timestamptz(6)

  @@map("schema_migrations")
}

model password_reset_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  token_hash String?
  expires_at DateTime? @default(now()) @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      User?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model appointments {
  id               Int       @id @default(autoincrement())
  customer_id      Int
  title            String
  description      String
  scheduled_at     DateTime? @default(now()) @db.Timestamptz(6)
  duration_minutes Int
  status           String
  price_offer      Decimal?  @db.Decimal
  admin_notes      String?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  users            User      @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
